{
  "version": "1.2.1",
  "apps": {
    "aider": {
      "name": "Aider",
      "description": "AI pair programming in your terminal",
      "author": "Paul Gauthier",
      "install_mode": "proot",
      "install_cmd": "pip install --break-system-packages aider-chat",
      "update_cmd": "pip install --upgrade --break-system-packages aider-chat",
      "uninstall_cmd": "pip uninstall -y aider-chat",
      "env_vars": [
        "ANTHROPIC_API_KEY",
        "OPENAI_API_KEY"
      ],
      "optional_env_vars": [
        "OPENAI_API_BASE",
        "ANTHROPIC_BASE_URL",
        "DEEPSEEK_API_KEY",
        "AIDER_MODEL"
      ],
      "executable": "aider"
    },
    "mimo": {
      "name": "MiMo Code",
      "description": "Terminal AI agent tailored for Android/Proot",
      "author": "XiaomiMiMo",
      "install_mode": "proot",
      "install_cmd": "pip install --break-system-packages mimocode",
      "update_cmd": "pip install --upgrade --break-system-packages mimocode",
      "uninstall_cmd": "pip uninstall -y mimocode",
      "env_vars": [
        "OPENAI_API_KEY"
      ],
      "optional_env_vars": [
        "OPENAI_API_BASE",
        "DEEPSEEK_API_KEY",
        "MIMO_MODEL"
      ],
      "executable": "mimo"
    },
    "agy": {
      "name": "Antigravity CLI (agy)",
      "description": "Google's powerful terminal agent (Native Go Binary)",
      "author": "Google",
      "install_mode": "proot",
      "install_cmd": "curl -sL https://antigravity.google/cli/install.sh | bash",
      "update_cmd": "agy update",
      "uninstall_cmd": "rm -f /usr/local/bin/agy /root/.local/bin/agy",
      "env_vars": [],
      "optional_env_vars": [
        "GEMINI_API_KEY",
        "ANTIGRAVITY_API_KEY"
      ],
      "executable": "agy"
    },
    "claude-code": {
      "name": "Claude Code",
      "description": "Anthropic's official terminal coding agent",
      "author": "Anthropic",
      "install_mode": "proot",
      "install_cmd": "npm install -g @anthropic-ai/claude-code --prefix /data/local/tmp/ancli/npm-global --cache /data/local/tmp/ancli/npm-cache --unsafe-perm",
      "update_cmd": "npm update -g @anthropic-ai/claude-code --prefix /data/local/tmp/ancli/npm-global --cache /data/local/tmp/ancli/npm-cache --unsafe-perm",
      "uninstall_cmd": "npm uninstall -g @anthropic-ai/claude-code --prefix /data/local/tmp/ancli/npm-global",
      "runtime_env": [
        "HOME=/data/local/tmp/ancli/npm-home"
      ],
      "env_vars": [],
      "optional_env_vars": [
        "ANTHROPIC_API_KEY",
        "ANTHROPIC_BASE_URL",
        "ANTHROPIC_MODEL"
      ],
      "executable": "claude"
    },
    "opencode": {
      "name": "OpenCode",
      "description": "Open-source terminal-based AI coding agent",
      "author": "Sst Labs",
      "install_mode": "proot",
      "install_cmd": "npm install -g opencode-ai --prefix /data/local/tmp/ancli/npm-global --cache /data/local/tmp/ancli/npm-cache --unsafe-perm",
      "update_cmd": "npm update -g opencode-ai --prefix /data/local/tmp/ancli/npm-global --cache /data/local/tmp/ancli/npm-cache --unsafe-perm",
      "uninstall_cmd": "npm uninstall -g opencode-ai --prefix /data/local/tmp/ancli/npm-global",
      "runtime_env": [
        "HOME=/data/local/tmp/ancli/npm-home"
      ],
      "env_vars": [
        "OPENAI_API_KEY"
      ],
      "optional_env_vars": [
        "OPENAI_API_BASE"
      ],
      "executable": "opencode"
    }
  }
}