{
  "version": "1.0.0",
  "apps": {
    "aider": {
      "name": "Aider",
      "description": "AI pair programming in your terminal",
      "author": "Paul Gauthier",
      "install_mode": "proot",
      "install_cmd": "pip install --break-system-packages aider-chat",
      "update_cmd": "pip install --upgrade --break-system-packages aider-chat",
      "uninstall_cmd": "pip uninstall -y aider-chat",
      "env_vars": [
        "ANTHROPIC_API_KEY",
        "OPENAI_API_KEY"
      ],
      "optional_env_vars": [
        "OPENAI_API_BASE",
        "ANTHROPIC_BASE_URL",
        "DEEPSEEK_API_KEY",
        "AIDER_MODEL"
      ],
      "executable": "aider"
    },
    "mimo": {
      "name": "MiMo Code",
      "description": "Terminal AI agent tailored for Android/Proot",
      "author": "XiaomiMiMo",
      "install_mode": "proot",
      "install_cmd": "curl -L https://github.com/XiaomiMiMo/MiMo-Code/releases/latest/download/mimocode-linux-arm64.tar.gz -o /tmp/mimo.tar.gz && tar -xzf /tmp/mimo.tar.gz -C /usr/local/bin && rm /tmp/mimo.tar.gz",
      "update_cmd": "curl -L https://github.com/XiaomiMiMo/MiMo-Code/releases/latest/download/mimocode-linux-arm64.tar.gz -o /tmp/mimo.tar.gz && tar -xzf /tmp/mimo.tar.gz -C /usr/local/bin && rm /tmp/mimo.tar.gz",
      "uninstall_cmd": "rm -f /usr/local/bin/mimo",
      "env_vars": [
        "OPENAI_API_KEY"
      ],
      "optional_env_vars": [
        "OPENAI_API_BASE",
        "DEEPSEEK_API_KEY",
        "MIMO_MODEL"
      ],
      "executable": "mimo"
    },
    "agy": {
      "name": "Antigravity CLI (agy)",
      "description": "Google's powerful terminal agent (Native Go Binary)",
      "author": "Google",
      "install_mode": "proot",
      "install_cmd": "curl -sL https://antigravity.google/cli/install.sh | bash -s -- --dir /usr/local/bin",
      "update_cmd": "agy update",
      "uninstall_cmd": "rm -f /usr/local/bin/agy /root/.local/bin/agy",
      "env_vars": [],
      "optional_env_vars": [
        "GEMINI_API_KEY",
        "ANTIGRAVITY_API_KEY",
        "HTTP_PROXY",
        "HTTPS_PROXY",
        "ALL_PROXY"
      ],
      "executable": "agy"
    },
    "claude-code": {
      "name": "Claude Code",
      "description": "Anthropic's official terminal coding agent",
      "author": "Anthropic",
      "install_mode": "proot",
      "install_cmd": "curl -L https://github.com/anthropics/claude-code/releases/latest/download/claude-linux-arm64.tar.gz -o /tmp/claude.tar.gz && tar -xzf /tmp/claude.tar.gz -C /usr/local/bin && rm /tmp/claude.tar.gz",
      "update_cmd": "curl -L https://github.com/anthropics/claude-code/releases/latest/download/claude-linux-arm64.tar.gz -o /tmp/claude.tar.gz && tar -xzf /tmp/claude.tar.gz -C /usr/local/bin && rm /tmp/claude.tar.gz",
      "uninstall_cmd": "rm -f /usr/local/bin/claude",
      "env_vars": [],
      "optional_env_vars": [
        "ANTHROPIC_API_KEY",
        "ANTHROPIC_BASE_URL",
        "ANTHROPIC_MODEL"
      ],
      "executable": "claude"
    },
    "opencode": {
      "name": "OpenCode",
      "description": "Open-source terminal-based AI coding agent",
      "author": "Sst Labs",
      "install_mode": "proot",
      "install_cmd": "curl -L https://github.com/anomalyco/opencode/releases/latest/download/opencode-linux-arm64.tar.gz -o /tmp/opencode.tar.gz && tar -xzf /tmp/opencode.tar.gz -C /usr/local/bin && rm /tmp/opencode.tar.gz",
      "update_cmd": "curl -L https://github.com/anomalyco/opencode/releases/latest/download/opencode-linux-arm64.tar.gz -o /tmp/opencode.tar.gz && tar -xzf /tmp/opencode.tar.gz -C /usr/local/bin && rm /tmp/opencode.tar.gz",
      "uninstall_cmd": "rm -f /usr/local/bin/opencode",
      "env_vars": [
        "OPENAI_API_KEY"
      ],
      "optional_env_vars": [
        "OPENAI_API_BASE"
      ],
      "executable": "opencode"
    }
  }
}